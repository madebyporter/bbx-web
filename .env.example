NUXT_PUBLIC_SUPABASE_URL=your-project-url-here
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# PostHog product analytics (client-side)
NUXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
# Optional. US ingest: us.i.posthog.com — EU: eu.i.posthog.com. Omit to use the SDK default.
NUXT_PUBLIC_POSTHOG_HOST=

# Server-only (Netlify env). Never expose to the client.
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Phase 2 onboarding reminder cron (Netlify function: send-onboarding-reminders)
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=hello@beatbox.studio
CRON_SECRET=generate-a-long-random-secret

# Support feedback form → Notion (server-only)
NOTION_API_KEY=secret_...
NOTION_SUPPORT_DATABASE_ID=38c9342f409d801b82e7d7fd23e8c94f